<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Don't rewrite if it's a real file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    # Don't rewrite if it's a real directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Rewrite all requests to index.php, preserving the original URL in an environment variable
    RewriteRule ^(.*)$ index.php [QSA,L,E=ORIGINAL_REQUEST_URI:%{REQUEST_URI}]
</IfModule>
